{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:7654/**" },
        { "url": "http://127.0.0.1:7654/*" },
        { "url": "http://127.0.0.1:7654" },
        { "url": "http://localhost:7654/**" },
        { "url": "http://localhost:7654/*" },
        { "url": "http://localhost:7654" }
      ]
    }
  ]
}
